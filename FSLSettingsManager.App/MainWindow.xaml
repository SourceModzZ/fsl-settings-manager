<Window x:Class="FSLSettingsManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FSL Settings Manager"
        Height="760"
        Width="1280"
        MinHeight="720"
        MinWidth="1160"
        WindowStartupLocation="CenterScreen"
        Background="#0B1020">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#121A2B" />
            <Setter Property="BorderBrush" Value="#25304A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#4F7CFF" />
            <Setter Property="BorderBrush" Value="#4F7CFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#1A2336" />
            <Setter Property="BorderBrush" Value="#2B3853" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ProfileBorder"
                                Background="#141E31"
                                BorderBrush="#25304A"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ProfileBorder" Property="Background" Value="#1B2A46" />
                                <Setter TargetName="ProfileBorder" Property="BorderBrush" Value="#4F7CFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ProfileBorder" Property="BorderBrush" Value="#3B4F73" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="32" FontWeight="Bold" Foreground="White" Text="FSL Settings Manager" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#AAB7D3"
                               Text="Detect ready FSL profiles, edit settings.ini, and save the updated configuration with one click." />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Margin="0,0,12,0"
                            Command="{Binding RefreshCommand}"
                            Content="Refresh"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Command="{Binding DownloadFslCommand}"
                            Content="Download FSL"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="White" Text="Detected Profiles" />

                    <StackPanel Grid.Row="1" Margin="0,16,0,20">
                        <TextBlock FontSize="14" Foreground="#AAB7D3" Text="{Binding StatusTitle}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="#7F8DAA"
                                   TextWrapping="Wrap"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>

                    <ListBox Grid.Row="2" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="White" Text="{Binding UserName}" />
                                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="#7F8DAA" Text="{Binding StatusText}" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="#AAB7D3"
                                               Text="{Binding SettingsFilePath}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="White" Text="Settings Editor" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="#AAB7D3"
                                       TextWrapping="Wrap"
                                       Text="Use the switches below to update the selected FSL profile. Changes are written back to settings.ini." />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding OpenSelectedFolderCommand}"
                                Content="Open Folder"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,20,0,0"
                            Padding="16"
                            Background="#0F1626"
                            BorderBrush="#25304A"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="#7F8DAA" Text="Selected Profile" />
                            <TextBlock Margin="0,6,0,0" FontSize="18" FontWeight="SemiBold" Foreground="White" Text="{Binding SelectedProfileName}" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="#AAB7D3"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedProfilePath}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0,16,0,0"
                            Padding="16"
                            Background="#111C31"
                            BorderBrush="#27406A"
                            BorderThickness="1"
                            CornerRadius="16"
                            Visibility="{Binding ShowNotice, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="White" Text="FSL required" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="13"
                                       Foreground="#C4D3F1"
                                       TextWrapping="Wrap"
                                       Text="{Binding NoticeMessage}" />
                            <Button Width="170"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding DownloadFslCommand}"
                                    Content="Open Download Page"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Settings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,14"
                                            Padding="18"
                                            Background="#141E31"
                                            BorderBrush="#25304A"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            IsEnabled="{Binding DataContext.IsEditorEnabled, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock FontSize="13" Foreground="#7F8DAA" Text="{Binding Section}" />
                                                <TextBlock Margin="0,4,0,0" FontSize="16" FontWeight="SemiBold" Foreground="White" Text="{Binding Title}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="#AAB7D3"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Description}" />
                                            </StackPanel>

                                            <CheckBox Grid.Column="1"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding Value, Mode=TwoWay}"
                                                      Content="Enabled" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="5" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#7F8DAA"
                                   Text="{Binding FooterMessage}" />

                        <Button Grid.Column="1"
                                Width="160"
                                Command="{Binding ApplyCommand}"
                                Content="Apply"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
